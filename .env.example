# ─────────────────────────────────────────────────────────────
# undoverse.in — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. See README for where to obtain each value.
# ─────────────────────────────────────────────────────────────

# --- Database (Neon PostgreSQL) ---
# Pooled connection string used at runtime (PgBouncer / serverless).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/undoverse?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/undoverse?sslmode=require"

# --- Auth.js v5 ---
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-secret"

# --- GitHub OAuth App ---
# Create at https://github.com/settings/developers
# Authorization callback URL: https://undoverse.in/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# --- Public app config ---
# The root domain that wildcard subdomains hang off of.
NEXT_PUBLIC_ROOT_DOMAIN="undoverse.in"
# Full public URL of the app (used for absolute links & OG tags).
NEXT_PUBLIC_APP_URL="https://undoverse.in"
